# ============================================================
# SubTrack 환경변수 예시 파일
# ⚠️ 실제 시크릿 값을 이 파일에 절대 작성하지 마세요.
# .env 파일을 생성하고 여기 값들을 채워 사용하세요.
# ============================================================

# ── 앱 기본 설정 ───────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── 데이터베이스 (PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://subtrack:YOUR_DB_PASSWORD@localhost:5432/subtrack_dev
POSTGRES_PASSWORD=YOUR_DB_PASSWORD

# ── 캐시 / 세션 (Redis) ────────────────────────────────────
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ── JWT 인증 ────────────────────────────────────────────────
JWT_ACCESS_SECRET=YOUR_JWT_ACCESS_SECRET_32CHARS_MIN
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_32CHARS_MIN
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── 금융 데이터 암호화 (AES-256) ────────────────────────────
# 32바이트(256비트) 랜덤 키 — AWS Secrets Manager 연동 권장
ENCRYPTION_KEY=YOUR_32_BYTE_HEX_ENCRYPTION_KEY

# ── 마이데이터 API ───────────────────────────────────────────
MYDATA_CLIENT_ID=YOUR_MYDATA_CLIENT_ID
MYDATA_CLIENT_SECRET=YOUR_MYDATA_CLIENT_SECRET
MYDATA_API_BASE_URL=https://api.mydata.go.kr

# ── AI 엔진 내부 통신 ────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_INTERNAL_SECRET=YOUR_AI_ENGINE_INTERNAL_SECRET

# ── AWS ─────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=subtrack-assets
AWS_SES_FROM_EMAIL=noreply@subtrack.app

# ── Firebase Cloud Messaging (Android Push) ──────────────────
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY

# ── APNs (iOS Push) ─────────────────────────────────────────
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APNS_TEAM_ID
# p8 인증서 내용 (줄바꿈은 \n으로 이스케이프)
APNS_PRIVATE_KEY=YOUR_APNS_PRIVATE_KEY_CONTENT

# ── Twilio (SMS) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=+821000000000

# ── Python AI 엔진 전용 ──────────────────────────────────────
PYTHON_ENV=development
AI_ENGINE_DATABASE_URL=postgresql://subtrack:YOUR_DB_PASSWORD@localhost:5432/subtrack_dev
INTERNAL_API_SECRET=YOUR_AI_ENGINE_INTERNAL_SECRET
