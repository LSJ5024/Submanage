# ============================================================
# SubTrack 환경변수 — 무료 스택 (신용카드 불필요)
# ============================================================
# 가입 링크 (모두 GitHub 계정으로 로그인):
#   DB    → https://neon.tech
#   Redis → https://upstash.com
#   Email → https://resend.com
#   Web   → https://vercel.com
#   API   → https://render.com
# ============================================================

# ── 앱 기본 ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ── PostgreSQL (Neon 무료 0.5GB) ──────────────────────────────
# Neon → 프로젝트 생성 → Connection string 복사
DATABASE_URL=postgresql://USER:PASS@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Redis (Upstash 무료 10K 명령/일) ──────────────────────────
# Upstash → Database 생성 → .env 탭 → REDIS_URL 복사
REDIS_URL=rediss://default:PASSWORD@HOST:PORT

# ── JWT (랜덤 32바이트 생성 필수) ─────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_32BYTES
JWT_REFRESH_SECRET=CHANGE_ME_32BYTES
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── AES-256 암호화 키 (64자리 hex) ────────────────────────────
ENCRYPTION_KEY=CHANGE_ME_64HEX

# ── 마이데이터 (학교 과제: mock 사용) ─────────────────────────
MYDATA_CLIENT_ID=mock_client_id
MYDATA_CLIENT_SECRET=mock_client_secret
MYDATA_API_BASE_URL=https://testbed.mydata.go.kr

# ── AI 엔진 ────────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_INTERNAL_SECRET=CHANGE_ME_RANDOM
SCHEDULER_SECRET=CHANGE_ME_RANDOM

# ── 이메일 (Resend 무료 3,000건/월) ──────────────────────────
# Resend → API Keys → Create → 복사
RESEND_API_KEY=re_XXXXXXXXXXXX
RESEND_FROM_EMAIL=SubTrack <onboarding@resend.dev>

# ── 푸시 알림 (Firebase 무료 — 생략 시 skip) ──────────────────
FCM_SERVER_KEY=

# ── SMS (Twilio 유료 — 생략 시 자동 skip) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── AI 엔진 Python ─────────────────────────────────────────────
PYTHON_ENV=development
INTERNAL_API_SECRET=CHANGE_ME_RANDOM
