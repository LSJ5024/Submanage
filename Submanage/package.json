{
  "name": "subtrack",
  "version": "1.0.0",
  "private": true,
  "description": "SubTrack — 구독 통합 관리 플랫폼 모노레포",
  "scripts": {
    "build": "pnpm -r build",
    "vercel-build": "pnpm --filter @subtrack/shared build && pnpm --filter @subtrack/web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "dev:api": "pnpm --filter @subtrack/api dev",
    "dev:web": "pnpm --filter @subtrack/web dev",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md}": "prettier --write",
    "*.py": "black"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "bcrypt", "esbuild", "prisma"]
  }
}
