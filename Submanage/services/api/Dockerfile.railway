FROM node:20-alpine AS builder

WORKDIR /app

# OpenSSL 설치 (Prisma 엔진 빌드에 필요)
RUN apk add --no-cache openssl

RUN npm install -g pnpm

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/shared/package.json  ./packages/shared/
COPY services/api/package.json     ./services/api/

RUN pnpm install --frozen-lockfile --shamefully-hoist

COPY tsconfig.base.json  ./
COPY packages/shared/    ./packages/shared/
COPY services/api/       ./services/api/

RUN pnpm --filter @subtrack/shared build
RUN pnpm --filter @subtrack/api    build
RUN pnpm --filter @subtrack/api    db:generate

FROM node:20-alpine AS runner

# OpenSSL 설치 (Prisma 런타임 실행에 필요)
RUN apk add --no-cache openssl

RUN addgroup --system --gid 1001 nodejs && \
    adduser  --system --uid  1001 subtrack

WORKDIR /app

COPY --from=builder --chown=subtrack:nodejs /app/node_modules              ./node_modules
COPY --from=builder --chown=subtrack:nodejs /app/services/api/dist         ./dist
COPY --from=builder --chown=subtrack:nodejs /app/services/api/prisma       ./prisma
COPY --from=builder --chown=subtrack:nodejs /app/packages/shared/dist      ./packages/shared/dist
COPY --from=builder --chown=subtrack:nodejs /app/packages/shared/package.json ./packages/shared/package.json

USER subtrack

EXPOSE 3000
ENV NODE_ENV=production

HEALTHCHECK --interval=15s --timeout=5s --start-period=30s \
  CMD wget -qO- http://localhost:3000/health || exit 1

CMD ["node", "dist/app.js"]
